PORT="5001"
HOST="0.0.0.0"
NODE_ENV="development"
QUEUES_ENABLED="false"
CACHE_ENABLED="true"

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="your_jwt_secret_here_min_32_chars_change_me"
JWT_EXPIRE="15m"
JWT_COOKIE_NAME="warehouse_access_token"
JWT_COOKIE_SECURE="false"
JWT_COOKIE_SAME_SITE="lax"
JWT_COOKIE_MAX_AGE_MS="900000"
JWT_REFRESH_DAYS="7"
JWT_REFRESH_COOKIE_NAME="warehouse_refresh_token"
JWT_ROTATE_THRESHOLD_SEC="300"

AUTH_MAX_LOGIN_ATTEMPTS="5"
AUTH_LOCKOUT_MINUTES="15"
CSRF_PROTECTION_ENABLED="false"

ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@warehouse.local"
ADMIN_BOOTSTRAP_PASSWORD="change_this_password_in_production"

SUPERADMIN_USERNAME="superadmin"
SUPERADMIN_EMAIL="superadmin@warehouse.local"
SUPERADMIN_PASSWORD="change_this_password_in_production"

DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=verify-full"

# Comma-separated frontend origins (required in production)
CORS_ORIGIN="http://localhost:3000,http://localhost:5001"

# Production: cookie-only auth (no Bearer header, no token in JSON body)
JWT_ALLOW_BEARER="true"
AUTH_RETURN_TOKEN_IN_BODY="true"
REGISTRATION_ENABLED="true"

# Required in production for kiosk/device attendance endpoints
DEVICE_API_KEY=""

APP_TIMEZONE_OFFSET_MINUTES="180"

TRUST_PROXY="false"
REDIS_URL="redis://127.0.0.1:6379"
TOKEN_REVOCATION_STRICT="false"
BCRYPT_ROUNDS="12"
THROTTLE_TTL_MS="60000"
THROTTLE_LIMIT="120"
PRISMA_SLOW_QUERY_MS="800"
