generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?
  permissions String[]   @default([])
  users       User[]
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("roles")
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  username             String                @unique
  email                String?               @unique
  passwordHash         String
  roleId               String?               @db.Uuid
  role                 Role?                 @relation(fields: [roleId], references: [id], onDelete: Restrict)
  status               String                @default("active")
  failedLoginAttempts  Int                   @default(0)
  lockoutUntil         DateTime?
  lastLogin            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  employee             Employee?
  biometricCredentials BiometricCredential[]

  @@index([lockoutUntil])
  @@map("users")
}

model BiometricCredential {
  id           String    @id @default(uuid()) @db.Uuid
  keyId        String
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKeyDer Bytes
  deviceName   String?
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@unique([userId, keyId])
  @@map("biometric_credentials")
}

model Employee {
  id                        String                @id @default(uuid()) @db.Uuid
  employeeId                String                @unique
  biometricNumber           Int?                  @unique
  name                      String
  userId                    String?               @unique @db.Uuid
  user                      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  mobile                    String?
  residence                 String?               @db.VarChar(200)
  nationalId                String?               @unique
  dateOfBirth               DateTime?             @db.Date
  gender                    String?
  jobTitle                  String?
  profession                String?
  hourlyRate                Decimal               @db.Decimal(10, 2)
  dailyRate                 Decimal?              @db.Decimal(10, 2)
  baseSalary                Decimal?              @db.Decimal(14, 2)
  livingAllowance           Decimal?              @db.Decimal(14, 2)
  currency                  String                @default("SYP")
  scheduledStart            String?
  scheduledEnd              String?
  employmentStartDate       DateTime?             @db.Date
  terminationDate           DateTime?             @db.Date
  terminationType           String? // resignation | termination
  terminationReason         String?
  terminationNotes          String?
  financialSettlementStatus String                @default("pending") // pending | completed
  financialSettlementDate   DateTime?             @db.Date
  rehireDate                DateTime?             @db.Date
  isSettled                 Boolean               @default(false)
  isFinanciallySettled      Boolean               @default(false)
  department                String                @default("Warehouse")
  departmentId              String?               @db.Uuid
  departmentEntity          Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  roleId                    String?               @db.Uuid
  role                      Role?                 @relation(fields: [roleId], references: [id], onDelete: SetNull)
  status                    String                @default("active")
  workDaysInPeriod          Int                   @default(26)
  hoursPerDay               Int                   @default(8)
  overtimeCalculation       Json?
  gracePeriodMinutes        Int                   @default(5)
  attendanceRecords         AttendanceRecord[]
  dailyAttendanceLogs       DailyAttendanceLog[]  @relation("DailyAttendanceLogs")
  advances                  EmployeeAdvance[]
  leaveRequests             LeaveRequest[]
  terminationRecords        TerminationRecord[]
  financialSettlements      FinancialSettlement[]
  rehireRecords             RehireRecord[]
  payrollReceipts           PayrollReceipt[]

  employeeSalary    EmployeeSalary?
  employeeInsurance EmployeeInsurance?
  employeeBonuses   EmployeeBonus[]
  employeePenalties EmployeePenalty[]
  payrollInputs     PayrollInput[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  busPassengers BusPassenger[]

  @@index([status])
  @@index([name])
  @@index([createdAt])
  @@index([status, employeeId])
  @@index([department, status])
  @@index([departmentId])
  @@index([status, createdAt])
  @@index([status, departmentId])
  @@index([departmentId, status])
  @@map("employees")
}

model Department {
  id            String     @id @default(uuid()) @db.Uuid
  name          String     @unique
  manager       String?
  establishedAt DateTime?
  employees     Employee[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([createdAt])
  @@map("departments")
}

enum LeaveRequestType {
  PAID
  UNPAID
  SICK
  ADMIN
  DEATH
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id         String             @id @default(uuid()) @db.Uuid
  employeeId String
  employee   Employee           @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  leaveType  LeaveRequestType
  status     LeaveRequestStatus @default(PENDING)
  isPaid     Boolean            @default(false)
  startDate  DateTime           @db.Date
  endDate    DateTime           @db.Date
  // حقول الإجازة الساعية
  isHourly   Boolean            @default(false)
  startTime  String? // HH:mm — وقت بداية الإجازة الساعية
  endTime    String? // HH:mm — وقت نهاية الإجازة الساعية
  reason     String?
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([employeeId])
  @@index([employeeId, status])
  @@index([leaveType, status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model Device {
  id        String    @id @default(uuid()) @db.Uuid
  deviceId  String    @unique
  name      String
  location  String
  model     String    @default("ZK Teco")
  ip        String?
  port      Int?
  status    String    @default("active")
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([location, status, createdAt])
  @@map("devices")
}

model AttendanceRecord {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  timestamp  DateTime
  type       String
  deviceId   String?
  location   String?
  source     String   @default("device")
  verified   Boolean  @default(false)
  notes      String?
  date       String
  shiftPair  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
  @@index([date, timestamp])
  @@index([employeeId, timestamp])
  @@index([date, employeeId])
  @@index([deviceId, timestamp])
  @@index([employeeId, type, date])
  @@index([employeeId, date, timestamp])
  @@index([date, type])
  @@index([employeeId, date, type])
  // Prevents duplicate punches (same employee + timestamp + type). The migration
  // de-duplicates existing rows (keeping the earliest by createdAt) before this
  // is applied. Application code also guards via a 30-minute re-punch window.
  @@unique([employeeId, timestamp, type])
  @@map("attendance_records")
}

// ---------------------------------------------------------------------------
// Daily Attendance Logs — Event-based logging for audit trail & biometric integration
// ---------------------------------------------------------------------------
enum DailyRecordType {
  ABSENCE // غياب
  DELAY_MINUTES // تأخير بالدقائق
  OVERTIME_MINUTES // إضافي بالدقائق
  PAID_LEAVE // إجازة مدفوعة
  UNPAID_LEAVE // إجازة غير مدفوعة
  SICK_LEAVE // إجازة مرضية
  ADMIN_LEAVE // إجازة إدارية
  DEATH_LEAVE // إجازة وفاة
  EARLY_LEAVE_MINUTES // خروج مبكر بالدقائق
}

model DailyAttendanceLog {
  id         String          @id @default(uuid()) @db.Uuid
  employeeId String
  employee   Employee        @relation("DailyAttendanceLogs", fields: [employeeId], references: [employeeId], onDelete: Cascade)
  date       DateTime        @db.Date
  recordType DailyRecordType
  value      Decimal         @db.Decimal(10, 2) // e.g., 1 (for 1 day) or 120 (for 120 minutes)
  notes      String?         @db.Text
  source     String          @default("manual") // manual | biometric | calculated
  createdBy  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([employeeId, date])
  @@index([date])
  @@index([employeeId, recordType, date])
  @@index([recordType, date])
  // Prevents duplicate calculated/manual log rows for the same employee+day+type.
  // Makes aggregateEmployeeDay's deleteMany+create idempotent under concurrency.
  @@unique([employeeId, date, recordType, source])
  @@map("daily_attendance_logs")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  sku          String   @unique
  name         String
  category     String
  unitPrice    Decimal  @db.Decimal(12, 2)
  costPrice    Decimal  @db.Decimal(12, 2)
  reorderLevel Int      @default(10)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stockLevels StockLevel[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([category, status, createdAt])
  @@map("products")
}

model StockLevel {
  id        String   @id @default(uuid()) @db.Uuid
  sku       String
  location  String
  quantity  Int      @default(0)
  reserved  Int      @default(0)
  available Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product? @relation(fields: [sku], references: [sku], onDelete: Cascade)

  @@unique([sku, location])
  @@map("stock_levels")
}

model ImportJob {
  id          String   @id @default(uuid()) @db.Uuid
  jobId       String   @unique
  entity      String
  fileName    String
  uploadedBy  String
  uploadedAt  DateTime @default(now())
  status      String   @default("pending")
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  errorRows   Int      @default(0)
  errors      Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entity, uploadedAt])
  @@index([uploadedAt])
  @@index([status, uploadedAt])
  @@map("import_jobs")
}

model PayrollRun {
  id              String           @id @default(uuid()) @db.Uuid
  runId           String           @unique
  periodStart     DateTime         @db.Date
  periodEnd       DateTime         @db.Date
  periodType      String           @default("monthly")
  runDate         DateTime         @default(now())
  runBy           String?
  status          String           @default("draft")
  approvalStatus  String           @default("pending")
  approvedBy      String?
  approvalDate    DateTime?
  totalEmployees  Int              @default(0)
  totalGrossPay   Decimal          @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal          @default(0) @db.Decimal(14, 2)
  totalNetPay     Decimal          @default(0) @db.Decimal(14, 2)
  currency        String           @default("SYP")
  notes           String?
  items           PayrollItem[]
  receipts        PayrollReceipt[]

  @@index([runDate])
  @@index([status, runDate])
  @@index([approvalStatus, runDate])
  @@index([periodStart])
  @@index([periodStart, periodEnd])
  @@map("payroll_runs")
}

model PayrollItem {
  id                    String   @id @default(uuid()) @db.Uuid
  payrollRunId          String   @db.Uuid
  employeeId            String
  employeeName          String
  department            String?
  attendanceBasedSalary Decimal  @db.Decimal(14, 2)
  hoursWorked           Decimal  @db.Decimal(8, 2)
  hourlyRate            Decimal  @db.Decimal(10, 2)
  grossPay              Decimal  @db.Decimal(14, 2)
  totalBonuses          Decimal  @default(0) @db.Decimal(14, 2)
  totalDeductions       Decimal  @db.Decimal(14, 2)
  netPay                Decimal  @db.Decimal(14, 2)
  netPayRounded         Decimal  @default(0) @db.Decimal(14, 2)
  roundingDifference    Decimal  @default(0) @db.Decimal(14, 2)
  netPayWithAdvance     Decimal  @default(0) @db.Decimal(14, 2)
  earlyLeaveMinutes     Int      @default(0)
  earlyLeaveDeduction   Decimal  @default(0) @db.Decimal(14, 2)
  /** خصم اشتراك الباص — منفصل عن باقي الخصومات لعرضه بالأزرق */
  busDeduction          Decimal  @default(0) @db.Decimal(14, 2)
  anomalies             String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  run PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([payrollRunId, employeeId])
  @@map("payroll_items")
}

model PayrollReceipt {
  id           String      @id @default(uuid()) @db.Uuid
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  month        String
  payrollRunId String?     @db.Uuid
  payrollRun   PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)
  isReceived   Boolean     @default(false)
  receivedAt   DateTime?   @db.Date
  receivedBy   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([employeeId, month])
  @@index([month])
  @@index([payrollRunId])
  @@index([month, isReceived])
  @@map("payroll_receipts")
}

// ---------------------------------------------------------------------------
// Payroll Inputs — per-employee values used in payroll formula
// ---------------------------------------------------------------------------
model PayrollInput {
  id                         String   @id @default(uuid()) @db.Uuid
  employeeId                 String
  employee                   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  periodStart                DateTime @db.Date
  periodEnd                  DateTime @db.Date
  lateMinutes                Int      @default(0)
  earlyLeaveMinutes          Int      @default(0)
  absenceDays                Int?
  sickLeaveDays              Int      @default(0)
  adminLeaveDays             Int      @default(0)
  unpaidLeaveDays            Int      @default(0)
  deathLeaveDays             Int      @default(0)
  unpaidHours                Decimal  @default(0) @db.Decimal(8, 2)
  overtimeRegularMinutes     Int      @default(0)
  overtimeWeekendDays        Decimal  @default(0) @db.Decimal(6, 2)
  penaltyAmount              Decimal? @db.Decimal(14, 2)
  clothingDeduction          Decimal  @default(0) @db.Decimal(14, 2)
  bonusAdjustment            Decimal? @db.Decimal(14, 2)
  advanceAmount              Decimal? @db.Decimal(14, 2)
  insuranceAmount            Decimal? @db.Decimal(14, 2)
  transportAllowanceOverride Decimal? @db.Decimal(14, 2)
  notes                      String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([employeeId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([employeeId, periodStart])
  @@map("payroll_inputs")
}

// ---------------------------------------------------------------------------
// Salary & Occupation — base salary, allowances, incentives per employee
// ---------------------------------------------------------------------------
model EmployeeSalary {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  profession              String?
  baseSalary              Decimal  @db.Decimal(14, 2)
  lumpSumSalary           Decimal  @default(0) @db.Decimal(14, 2) // الراتب المقطوع
  livingAllowance         Decimal  @default(0) @db.Decimal(14, 2) // بدل غلاء معيشة
  // البدلات المحسوبة تلقائياً من الفرق
  responsibilityAllowance Decimal  @default(0) @db.Decimal(14, 2) // 50% من الفرق
  extraEffortAllowance    Decimal  @default(0) @db.Decimal(14, 2) // 30% من الفرق
  productionIncentive     Decimal  @default(0) @db.Decimal(14, 2) // 20% من الفرق
  // التأمينات (تُدخل يدوياً)
  insuranceAmount         Decimal  @default(0) @db.Decimal(14, 2)
  transportAllowance      Decimal  @default(0) @db.Decimal(14, 2)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([employeeId])
  @@map("employee_salaries")
}

// ---------------------------------------------------------------------------
// Advances (سلف) — employee advance/loan records
// ---------------------------------------------------------------------------
model EmployeeAdvance {
  id                String   @id @default(uuid()) @db.Uuid
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  advanceType       String   @default("salary")
  totalAmount       Decimal  @db.Decimal(14, 2)
  installmentAmount Decimal  @default(0) @db.Decimal(14, 2)
  remainingAmount   Decimal  @db.Decimal(14, 2)
  notes             String?
  issueDate         DateTime @default(now())
  period            String? // "YYYY-MM" — auto-filled from issueDate
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([employeeId])
  @@index([employeeId, issueDate])
  @@index([employeeId, remainingAmount])
  @@index([employeeId, period])
  @@index([period, createdAt])
  @@map("employee_advances")
}

model DeletedRecordHistory {
  id         String    @id @default(uuid()) @db.Uuid
  entityType String
  recordId   String
  payload    Json
  deletedBy  String?
  deletedAt  DateTime  @default(now())
  restoredBy String?
  restoredAt DateTime?

  @@index([entityType, recordId])
  @@index([entityType, deletedAt])
  @@index([entityType, restoredAt, deletedAt])
  @@map("deleted_record_history")
}

// ---------------------------------------------------------------------------
// Insurance (تامينات) — social insurance details per employee
// ---------------------------------------------------------------------------
model EmployeeInsurance {
  id                   String    @id @default(uuid()) @db.Uuid
  employeeId           String    @unique
  employee             Employee  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  insuranceSalary      Decimal   @db.Decimal(14, 2)
  socialSecurityNumber String?
  registrationDate     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("employee_insurance")
}

// ---------------------------------------------------------------------------
// Bonuses & Assistance — per-period bonus and assistance amounts
// ---------------------------------------------------------------------------
model EmployeeBonus {
  id         String @id @default(uuid()) @db.Uuid
  employeeId String

  bonusAmount      Decimal  @default(0) @db.Decimal(14, 2)
  bonusReason      String?
  assistanceAmount Decimal  @default(0) @db.Decimal(14, 2)
  period           String? // e.g. "2026-04"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  employee         Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId])
  @@index([employeeId, period])
  @@index([period, createdAt])
  @@map("employee_bonuses")
}

// ---------------------------------------------------------------------------
// Penalties & Deductions — restaurant/clothing/administrative penalties
// ---------------------------------------------------------------------------
model EmployeePenalty {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String
  category   String
  amount     Decimal  @db.Decimal(14, 2)
  reason     String?
  issueDate  DateTime @default(now())
  period     String? // "YYYY-MM" — auto-filled from issueDate
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employeeId])
  @@index([employeeId, issueDate])
  @@index([employeeId, period])
  @@index([period, createdAt])
  @@map("employee_penalties")
}

model TerminationRecord {
  id              String   @id @default(uuid()) @db.Uuid
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  terminationDate DateTime @db.Date
  terminationType String
  reason          String
  notes           String?
  processedBy     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  rehireRecords RehireRecord[] @relation("TerminationToRehire")

  @@index([employeeId])
  @@index([terminationDate])
  @@index([terminationType])
  @@index([processedBy])
  @@index([employeeId, terminationDate])
  @@map("termination_records")
}

model FinancialSettlement {
  id                String   @id @default(uuid()) @db.Uuid
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  settlementDate    DateTime @db.Date
  processedBy       String
  finalSalaryAmount Decimal  @db.Decimal(14, 2)
  deductions        Decimal  @default(0) @db.Decimal(14, 2)
  bonuses           Decimal  @default(0) @db.Decimal(14, 2)
  totalSettlement   Decimal  @db.Decimal(14, 2)
  status            String   @default("completed") // pending | completed
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([employeeId])
  @@index([settlementDate])
  @@index([status])
  @@index([processedBy])
  @@index([employeeId, status])
  @@map("financial_settlements")
}

model RehireRecord {
  id                    String   @id @default(uuid()) @db.Uuid
  employeeId            String
  employee              Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  rehireDate            DateTime @db.Date
  processedBy           String
  previousTerminationId String?  @db.Uuid
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  previousTermination TerminationRecord? @relation("TerminationToRehire", fields: [previousTerminationId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([rehireDate])
  @@index([processedBy])
  @@index([employeeId, rehireDate])
  @@map("rehire_records")
}

// ---------------------------------------------------------------------------
// Transportation — إدارة الباصات والنقل
// ---------------------------------------------------------------------------
model Bus {
  id                   String         @id @default(uuid()) @db.Uuid
  busId                String         @unique // كود الباص
  route                String // الخط / مسار الرحلة
  plateNumber          String         @unique // رقم اللوحة
  driverName           String // اسم السائق
  driverPhone          String // رقم السائق (10 أرقام سورية)
  totalCost            Decimal        @db.Decimal(14, 2) // التكلفة الإجمالية (ل.س)
  companyDeductionPct  Decimal        @db.Decimal(5, 2) // حسم الشركة بالنسبة المئوية
  capacity             Int // سعة الركاب
  // نسبة خصم أجرة النقل التي تُحسم من راتب الموظف (نسبة 0-100)
  employeeDeductionPct Decimal        @default(0) @db.Decimal(5, 2)
  status               String         @default("active") // active | inactive
  passengers           BusPassenger[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([status])
  @@index([route, status])
  @@map("buses")
}

model BusPassenger {
  id               String   @id @default(uuid()) @db.Uuid
  busId            String   @db.Uuid
  bus              Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  name             String? // optional passenger name for display
  subscriptionDate DateTime @default(now()) @db.Date
  status           String   @default("active") // active | inactive
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([busId, employeeId])
  @@index([employeeId])
  @@index([busId, status])
  @@map("bus_passengers")
}

// =============================================================================
// Audit Log — سجل التدقيق الكامل لكل العمليات الحساسة
// =============================================================================
model AuditLog {
  id String @id @default(cuid())

  /// من نفّذ العملية (userId)
  actorId String?

  /// اسم المستخدم المنفِّذ
  actorUsername String?

  /// نوع العملية: user.create | employee.update | payroll.run | auth.login ...
  action String

  /// نوع الكيان المتأثر: employee | user | payroll | attendance ...
  targetType String?

  /// معرّف الكيان المتأثر
  targetId String?

  /// عنوان الـ IP
  ipAddress String?

  /// User Agent (المتصفح أو التطبيق)
  userAgent String?

  /// بيانات إضافية (JSON حر)
  metadata Json?

  createdAt DateTime @default(now())

  /// فهرس للبحث بالمستخدم والتاريخ
  @@index([actorId, createdAt])
  @@index([targetType, createdAt])
  @@index([targetId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

enum NotificationType {
  CHECK_IN
  CHECK_OUT
  BONUS
  PENALTY
  ADVANCE
  LEAVE
  TERMINATION
  RESIGNATION
  LATE
  ABSENT
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  DANGER
}

model Notification {
  id           String               @id @default(uuid()) @db.Uuid
  type         NotificationType
  severity     NotificationSeverity @default(INFO)

  /// عنوان الإشعار (بالعربية)
  title        String
  /// نص الإشعار (بالعربية)
  message      String

  /// الموظف المرتبط بالحدث (إن وجد)
  employeeId   String?
  employeeName String?

  /// نوع الكيان المصدر: bonus | penalty | advance | leave | attendance | employee
  entityType   String?
  /// معرّف السجل المصدر
  entityId     String?

  /// بيانات إضافية حرة (JSON)
  metadata     Json?

  /// مفتاح إلغاء التكرار (يستخدمه تنبيه الغياب لمنع التكرار في نفس اليوم)
  dedupeKey    String?              @unique

  isRead       Boolean              @default(false)
  readAt       DateTime?

  /// تجاهل نهائي (زر "تجاهل" لتنبيهات الغياب/التأخير)
  isDismissed  Boolean              @default(false)
  dismissedAt  DateTime?
  dismissedBy  String?

  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([isRead, createdAt])
  @@index([isDismissed, type])
  @@index([type, createdAt])
  @@index([employeeId])
  @@map("notifications")
}
