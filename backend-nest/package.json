{
  "name": "warehouse-system-backend-nest",
  "version": "1.0.0",
  "description": "Warehouse Management System - NestJS Backend",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "docker:build": "docker build -t warehouse-backend:prod .",
    "start": "node dist/main.js",
    "prestart:dev": "npm run prisma:generate",
    "start:dev": "nest start --watch",
    "db:push": "prisma db push --accept-data-loss",
    "start:worker:payroll": "ts-node src/payroll-worker.ts",
    "dev": "npm run infra:up && npm run start:dev",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis",
    "start:prod": "node dist/main",
    "start:worker:payroll:prod": "node dist/payroll-worker.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --accept-data-loss",
    "seed:demo": "node scripts/seed-demo.js",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:salary": "npx jest ./test/salary.calculate-allowances.e2e-spec.ts --config ./test/jest-e2e.json -i --runInBand",
    "test:security": "npm run test:e2e -- security.e2e-spec.ts",
    "test:imports": "npm run test:e2e -- imports.e2e-spec.ts",
    "test:files": "npm run test:e2e -- files.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.72.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.4.0",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "chokidar": "^4.0.0",
    "jest": "^30.3.0",
    "kill-port": "^2.0.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.4",
    "@hono/node-server": "^1.19.13"
  }
}
