    {
      "name": "02 Auth",
      "item": [
        {
          "name": "POST Login (superadmin)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('login 200', () => pm.response.to.have.status(200));",
            "const d = pm.response.json();",
            "if (d.token) pm.collectionVariables.set('token', d.token);"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST Login (admin)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const d = pm.response.json();",
            "if (d.token) pm.collectionVariables.set('token', d.token);"
          ]}}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"REPLACE_WITH_PASSWORD\"\n}" },
            "url": "{{baseUrl}}/auth/login"
