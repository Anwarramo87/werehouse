            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"{{employeeId}}\",\n  \"timestamp\": \"2026-04-05T08:00:00.000Z\",\n  \"type\": \"IN\",\n  \"deviceId\": \"{{deviceId}}\",\n  \"location\": \"Main Gate\",\n  \"source\": \"manual\",\n  \"verified\": true,\n  \"notes\": \"دخول صباحي\"\n}" },
