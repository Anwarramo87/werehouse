        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/attendance/daily-logs/summary/EMP001?month=2026-05",
          "host": ["{{base_url}}"],
          "path": ["attendance", "daily-logs", "summary", "EMP001"],
          "query": [
            {
              "key": "month",
              "value": "2026-05"
            }
          ]
        },
        "description": "الحصول على المجاميع الشهرية لموظف محدد (Aggregation) - هذا هو الـ Endpoint الأهم!"
      }
    },
    {
      "name": "Get Monthly Summary (All Employees)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/attendance/daily-logs/summary/all?month=2026-05",
          "host": ["{{base_url}}"],
          "path": ["attendance", "daily-logs", "summary", "all"],
          "query": [
            {
              "key": "month",
              "value": "2026-05"
            }
          ]
