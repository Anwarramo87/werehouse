        "description": "الحصول على المجاميع الشهرية لجميع الموظفين النشطين"
      }
    },
    {
      "name": "Get Employee Month Logs with Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/attendance/daily-logs/employee/EMP001/month/2026-05",
          "host": ["{{base_url}}"],
          "path": ["attendance", "daily-logs", "employee", "EMP001", "month", "2026-05"]
        },
        "description": "الحصول على السجلات اليومية + المجاميع لموظف في شهر محدد"
      }
    },
    {
      "name": "Get Daily Log by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/attendance/daily-logs/{{log_id}}",
          "host": ["{{base_url}}"],
          "path": ["attendance", "daily-logs", "{{log_id}}"]
        },
        "description": "الحصول على سجل يومي محدد بالـ ID"
      }
    },
    {
      "name": "Update Daily Log",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"value\": 2,\n  \"notes\": \"تم تعديل القيمة إلى يومين غياب\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/attendance/daily-logs/{{log_id}}",
          "host": ["{{base_url}}"],
          "path": ["attendance", "daily-logs", "{{log_id}}"]
        },
        "description": "تحديث سجل يومي موجود"
      }
    },
    {
      "name": "Delete Daily Log",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/attendance/daily-logs/{{log_id}}",
          "host": ["{{base_url}}"],
          "path": ["attendance", "daily-logs", "{{log_id}}"]
        },
        "description": "حذف سجل يومي"
      }
    }
  ],
  "variable": [
