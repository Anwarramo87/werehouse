      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/attendance/daily-logs?recordType=ABSENCE&startDate=2026-05-01&endDate=2026-05-31",
          "host": ["{{base_url}}"],
          "path": ["attendance", "daily-logs"],
          "query": [
            {
              "key": "recordType",
              "value": "ABSENCE"
            },
            {
              "key": "startDate",
              "value": "2026-05-01"
            },
            {
              "key": "endDate",
              "value": "2026-05-31"
            }
          ]
        },
        "description": "الحصول على السجلات اليومية حسب النوع (غياب، تأخير، إلخ)"
      }
    },
