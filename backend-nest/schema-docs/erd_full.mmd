erDiagram
  ROLE {
    UUID id PK
    STRING name UQ
    STRING description
    STRING[] permissions
    DATETIME createdAt
    DATETIME updatedAt
  }

  USER {
    UUID id PK
    STRING username UQ
    STRING email UQ
    STRING passwordHash
    UUID roleId FK
    STRING status
    INT failedLoginAttempts
    DATETIME lockoutUntil
    DATETIME lastLogin
    DATETIME createdAt
    DATETIME updatedAt
  }

  EMPLOYEE {
    UUID id PK
    STRING employeeId UQ
    STRING name
    STRING email UQ
    STRING mobile
    STRING nationalId UQ
    DATE birthDate
    DATE dateOfBirth
    STRING gender
    STRING jobTitle
    STRING profession
    DECIMAL hourlyRate
    DECIMAL baseSalary
    DECIMAL livingAllowance
    STRING currency
    STRING scheduledStart
    STRING scheduledEnd
    DATE employmentStartDate
    DATE terminationDate
    STRING terminationReason
    BOOLEAN isSettled
    STRING department
    UUID departmentId FK
    UUID roleId FK
    STRING status
    INT workDaysInPeriod
    INT hoursPerDay
    JSON overtimeCalculation
    INT gracePeriodMinutes
    DATETIME createdAt
    DATETIME updatedAt
  }

  DEPARTMENT {
    UUID id PK
    STRING name UQ
    DATETIME createdAt
    DATETIME updatedAt
  }

  DEVICE {
    UUID id PK
    STRING deviceId UQ
    STRING name
    STRING location
    STRING model
    STRING ip
    INT port
    STRING status
    DATETIME lastSync
    DATETIME createdAt
    DATETIME updatedAt
  }

  ATTENDANCE_RECORD {
    UUID id PK
    STRING employeeId FK
    DATETIME timestamp
    STRING type
    STRING deviceId
    STRING location
    STRING source
    BOOLEAN verified
    STRING notes
    STRING date
    JSON shiftPair
    DATETIME createdAt
    DATETIME updatedAt
  }

  DAILY_ATTENDANCE_LOG {
    UUID id PK
    STRING employeeId FK
    DATE date
    STRING recordType
    DECIMAL value
    TEXT notes
    STRING source
    STRING createdBy
    DATETIME createdAt
    DATETIME updatedAt
  }

  PRODUCT {
    UUID id PK
    STRING sku UQ
    STRING name
    STRING category
    DECIMAL unitPrice
    DECIMAL costPrice
    INT reorderLevel
    STRING status
    DATETIME createdAt
    DATETIME updatedAt
  }

  STOCK_LEVEL {
    UUID id PK
    STRING sku FK
    STRING location
    INT quantity
    INT reserved
    INT available
    DATETIME createdAt
    DATETIME updatedAt
  }

  IMPORT_JOB {
    UUID id PK
    STRING jobId UQ
    STRING entity
    STRING fileName
    STRING uploadedBy
    DATETIME uploadedAt
    STRING status
    INT totalRows
    INT successRows
    INT errorRows
    JSON errors
    DATETIME createdAt
    DATETIME updatedAt
  }

  PAYROLL_RUN {
    UUID id PK
    STRING runId UQ
    DATE periodStart
    DATE periodEnd
    STRING periodType
    DATETIME runDate
    STRING runBy
    STRING status
    STRING approvalStatus
    STRING approvedBy
    DATE approvalDate
    INT totalEmployees
    DECIMAL totalGrossPay
    DECIMAL totalDeductions
    DECIMAL totalNetPay
    STRING currency
    STRING notes
    DATETIME createdAt
    DATETIME updatedAt
  }

  PAYROLL_ITEM {
    UUID id PK
    UUID payrollRunId FK
