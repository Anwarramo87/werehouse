    DATETIME issueDate
    DATETIME createdAt
    DATETIME updatedAt
  }

  BUS {
    UUID id PK
    STRING busId UQ
    STRING route
    STRING plateNumber UQ
    STRING driverName
    STRING driverPhone
    DECIMAL totalCost
    DECIMAL companyDeductionPct
    INT capacity
    DECIMAL employeeDeductionAmount
    STRING status
    DATETIME createdAt
    DATETIME updatedAt
  }

  BUS_PASSENGER {
    UUID id PK
    UUID busId FK
    STRING employeeId
    DATE joinDate
    DATE leaveDate
    STRING status
    DATETIME createdAt
    DATETIME updatedAt
  }

  ROLE ||--o{ USER : "roleId"
  ROLE ||--o{ EMPLOYEE : "roleId"
  DEPARTMENT ||--o{ EMPLOYEE : "departmentId"
  EMPLOYEE ||--o{ ATTENDANCE_RECORD : "employeeId"
